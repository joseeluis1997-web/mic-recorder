<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Hasta La Vista</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: Arial, sans-serif;
    background: #f0f8ff;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow-x: hidden;
  }

  header {
    background: #29ABE2;
    width: 100%;
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  header img.logo {
    height: 36px;
    width: auto;
  }

  header span {
    color: white;
    font-size: 18px;
    font-weight: bold;
    letter-spacing: 0.5px;
  }

  .start-screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 30px 20px;
    gap: 16px;
    width: 100%;
    max-width: 500px;
  }

  .chepe-start {
    width: 180px;
    height: auto;
  }

  .lesson-badge {
    background: white;
    border-radius: 20px;
    padding: 6px 18px;
    color: #29ABE2;
    font-size: 18px;
    font-weight: bold;
    border: 2px solid #29ABE2;
  }

  #startButton {
    background: #29ABE2;
    color: white;
    border: none;
    border-radius: 30px;
    padding: 14px 36px;
    font-size: 18px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #startButton:disabled {
    background: #aaa;
    cursor: not-allowed;
  }

  .exercise-screen {
    display: none;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-width: 500px;
    padding: 12px 16px;
    gap: 12px;
  }

  .exercise-image-wrapper {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .exercise-image-wrapper img {
    width: 100%;
    display: block;
    border-radius: 16px;
  }

  .chepe-speech-area {
    width: 100%;
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding: 0 4px;
  }

  .chepe-figure {
    width: 90px;
    flex-shrink: 0;
  }

  .chepe-figure img {
    width: 100%;
    height: auto;
  }

  .speech-bubble {
    background: white;
    border-radius: 20px 20px 20px 4px;
    padding: 14px 16px;
    font-size: 16px;
    line-height: 1.5;
    color: #222;
    flex: 1;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    min-height: 60px;
    position: relative;
  }

  .speech-bubble.thinking {
    color: #aaa;
    font-style: italic;
  }

  .student-reply {
    width: 100%;
    background: #e8f5ff;
    border-radius: 20px 20px 4px 20px;
    padding: 12px 16px;
    font-size: 15px;
    color: #333;
    text-align: right;
    display: none;
  }

  #statusText {
    font-size: 13px;
    color: #888;
    text-align: center;
    min-height: 18px;
  }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: center;
    width: 100%;
    padding-bottom: 8px;
  }

  #micButton {
    background: #29ABE2;
    color: white;
    border: none;
    border-radius: 50%;
    width: 54px;
    height: 54px;
    font-size: 22px;
    cursor: pointer;
    flex-shrink: 0;
  }

  #micButton.recording {
    background: #e74c3c;
    animation: pulse 1s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  #userInput {
    flex: 1;
    padding: 12px 16px;
    border: 2px solid #29ABE2;
    border-radius: 30px;
    font-size: 15px;
    outline: none;
  }

  #sendButton {
    background: #29ABE2;
    color: white;
    border: none;
    border-radius: 30px;
    padding: 12px 18px;
    font-size: 15px;
    cursor: pointer;
    white-space: nowrap;
  }

  #sendButton:disabled { background: #aaa; }

  .session-complete {
    text-align: center;
    background: #e8f5e9;
    border-radius: 16px;
    padding: 16px;
    color: #2e7d32;
    font-size: 16px;
    display: none;
    width: 100%;
  }
</style>
</head>
<body>

<header>
  <img class="logo" src="https://static.wixstatic.com/media/cd2a90_7eed42c804464efa9c4d32397c6e0c4b~mv2.png" alt="Hasta La Vista">
  <span>Hasta La Vista</span>
</header>

<div class="start-screen" id="startScreen">
  <img class="chepe-start" src="https://static.wixstatic.com/media/cd2a90_6534aad0aaa142bf94ff94a7c30de465~mv2.png" alt="Chepe">
  <div class="lesson-badge" id="lessonCodeDisplay">...</div>
  <button id="startButton">Practicar 🎤</button>
</div>

<div class="exercise-screen" id="exerciseScreen">

  <div class="exercise-image-wrapper" id="exerciseImageWrapper" style="display:none;">
    <img id="exerciseImage" src="" alt="Ejercicio">
  </div>

  <div class="chepe-speech-area">
    <div class="chepe-figure">
      <img id="chepeImg" src="https://static.wixstatic.com/media/cd2a90_6534aad0aaa142bf94ff94a7c30de465~mv2.png" alt="Chepe">
    </div>
    <div class="speech-bubble thinking" id="speechBubble">
      ¡Hola! Preparando tu ejercicio...
    </div>
  </div>

  <div class="student-reply" id="studentReply"></div>

  <div id="statusText"></div>

  <div class="session-complete" id="sessionComplete">
    ✅ ¡Sesión completada! ¡Muy bien! Hasta la próxima con Chepe
  </div>

  <div class="input-row" id="inputRow">
    <button id="micButton">🎤</button>
    <input id="userInput" type="text" placeholder="Escribe aquí...">
    <button id="sendButton">Enviar</button>
  </div>

</div>

<script>
const WORKER_URL = 'https://chepe-ai.jose-1d1.workers.dev';
const CHEPE_IMAGES = [
  'https://static.wixstatic.com/media/cd2a90_6534aad0aaa142bf94ff94a7c30de465~mv2.png',
  'https://static.wixstatic.com/media/cd2a90_2740b835ab8d4659b31c4a4748965ca8~mv2.png'
];

const params = new URLSearchParams(window.location.search);
const lessonCode = (params.get('lesson') || 'BQ3C01').toUpperCase();
document.getElementById('lessonCodeDisplay').textContent = lessonCode;

let conversationHistory = [];
let mediaRecorder = null;
let audioChunks = [];
let isRecording = false;
let chepeImageIndex = 0;

function setChepeMessage(text, isThinking) {
  const bubble = document.getElementById('speechBubble');
  bubble.textContent = text;
  bubble.className = 'speech-bubble' + (isThinking ? ' thinking' : '');
  chepeImageIndex = (chepeImageIndex + 1) % CHEPE_IMAGES.length;
  document.getElementById('chepeImg').src = CHEPE_IMAGES[chepeImageIndex];
}

function setStudentReply(text) {
  const el = document.getElementById('studentReply');
  if (text) {
    el.textContent = 'Tú: ' + text;
    el.style.display = 'block';
  } else {
    el.style.display = 'none';
  }
}

function setStatus(text) {
  document.getElementById('statusText').textContent = text;
}

function playAudio(base64Audio) {
  const audio = new Audio(`data:audio/mpeg;base64,${base64Audio}`);
  audio.play().catch(e => console.log('Audio error:', e));
}

function endSession() {
  document.getElementById('inputRow').style.display = 'none';
  document.getElementById('sessionComplete').style.display = 'block';
  setStatus('');
}

async function sendToChepe(userMessage) {
  if (userMessage) {
    setStudentReply(userMessage);
    conversationHistory.push({ role: 'user', content: userMessage });
  }

  setChepeMessage('Pensando...', true);
  setStatus('');
  document.getElementById('sendButton').disabled = true;
  document.getElementById('micButton').disabled = true;

  try {
    const response = await fetch(`${WORKER_URL}/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        lessonCode,
        studentText: userMessage || 'START_SESSION',
        conversationHistory
      })
    });

    const data = await response.json();

    if (data.error) {
      setChepeMessage('⚠️ Error: ' + data.error, false);
      return;
    }

    if (data.imageUrl && data.imageUrl.length > 0) {
      const wrapper = document.getElementById('exerciseImageWrapper');
      const img = document.getElementById('exerciseImage');
      img.src = data.imageUrl;
      wrapper.style.display = 'block';
    }

    conversationHistory.push({ role: 'assistant', content: data.reply });
    setChepeMessage(data.reply, false);

    if (data.audio) {
      playAudio(data.audio);
    }

    if (data.sessionEnded) {
      setTimeout(() => endSession(), 3000);
    }

  } catch (err) {
    setChepeMessage('⚠️ Error de conexión', false);
    setStatus(err.message);
  } finally {
    document.getElementById('sendButton').disabled = false;
    document.getElementById('micButton').disabled = false;
  }
}

document.getElementById('startButton').addEventListener('click', async () => {
  document.getElementById('startScreen').style.display = 'none';
  document.getElementById('exerciseScreen').style.display = 'flex';
  await sendToChepe(null);
});

document.getElementById('sendButton').addEventListener('click', async () => {
  const input = document.getElementById('userInput');
  const message = input.value.trim();
  if (!message) return;
  input.value = '';
  await sendToChepe(message);
});

document.getElementById('userInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') document.getElementById('sendButton').click();
});

document.getElementById('micButton').addEventListener('click', async () => {
  const micBtn = document.getElementById('micButton');

  if (isRecording) {
    mediaRecorder.stop();
    isRecording = false;
    micBtn.classList.remove('recording');
    micBtn.textContent = '🎤';
    return;
  }

  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    audioChunks = [];
    mediaRecorder = new MediaRecorder(stream);

    mediaRecorder.ondataavailable = e => {
      if (e.data.size > 0) audioChunks.push(e.data);
    };

    mediaRecorder.onstop = async () => {
      setStatus('⏳ Transcribiendo...');
      micBtn.disabled = true;

      const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
      const formData = new FormData();
      formData.append('file', audioBlob, 'audio.webm');
      formData.append('model', 'whisper-1');
      formData.append('language', 'es');

      try {
        const response = await fetch(`${WORKER_URL}/transcribe`, {
          method: 'POST',
          body: formData
        });
        const data = await response.json();
        if (data.transcript) {
          await sendToChepe(data.transcript);
        } else {
          setStatus('⚠️ No se entendió. Intenta de nuevo.');
        }
      } catch (err) {
        setStatus('⚠️ Error: ' + err.message);
      } finally {
        micBtn.disabled = false;
        micBtn.textContent = '🎤';
        setStatus('');
      }
      stream.getTracks().forEach(t => t.stop());
    };

    mediaRecorder.start();
    isRecording = true;
    micBtn.classList.add('recording');
    micBtn.textContent = '⏹';
    setStatus('🎤 Grabando... toca de nuevo para parar');

  } catch (err) {
    setStatus('⚠️ No se puede acceder al micrófono: ' + err.message);
  }
});
</script>
</body>
</html>
